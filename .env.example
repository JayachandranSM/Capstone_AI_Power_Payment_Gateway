# Application
APP_ENV=development
SECRET_KEY=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://pguser:pgpassword@postgres:5432/payment_gateway
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=20
IDEMPOTENCY_TTL_SECONDS=86400

# Azure OpenAI - fill in your values
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_HEAVY_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_EMBEDDING_SMALL=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_LARGE=text-embedding-3-large
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# MFA
TOTP_ISSUER=PayGateway
MFA_ENABLED=true

# FX
FX_CACHE_TTL_SECONDS=3600

# Sandbox Payment
STRIPE_SECRET_KEY=sk_test_your_key_here
